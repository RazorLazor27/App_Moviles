<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PersonalExpenses.ViewModels"
             xmlns:models="clr-namespace:PersonalExpenses.Models"
             x:Class="PersonalExpenses.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#F3F4F6"
             Title="Gastos Personales">

    <Grid RowDefinitions="*" Padding="16">
        <!-- CollectionView containing the Header and the List -->
        <CollectionView ItemsSource="{Binding Transactions}"
                        SelectionMode="None">
            
            <!-- Header: Contains Dashboard and Form -->
            <CollectionView.Header>
                <VerticalStackLayout Spacing="16" Margin="0,0,0,16">
                    
                    <!-- App Title -->
                    <Label Text="Mis Finanzas"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           Margin="0,8,0,4" />

                    <!-- Balance Card (Violet/Indigo Gradient) -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#512BD4"
                            Padding="20"
                            HeightRequest="140">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0.0" />
                                <GradientStop Color="#4F46E5" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,6" Radius="10" Opacity="0.15" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *" VerticalOptions="Center">
                            <Label Grid.Row="0"
                                   Text="Balance Total"
                                   TextColor="#E0E7FF"
                                   FontSize="14" />
                            <Label Grid.Row="1"
                                   Text="{Binding TotalBalance, StringFormat='{0:C}'}"
                                   TextColor="#FFFFFF"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   VerticalOptions="End" />
                        </Grid>
                    </Border>

                    <!-- Income and Expense Summary (Two Columns) -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        
                        <!-- Income Card -->
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#FFFFFF"
                                Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="6" Opacity="0.05" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#10B981" VerticalOptions="Center" />
                                    <Label Text="Ingresos" TextColor="#6B7280" FontSize="12" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding TotalIncome, StringFormat='{0:C}'}"
                                       TextColor="#10B981"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Expense Card -->
                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#FFFFFF"
                                Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="6" Opacity="0.05" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#EF4444" VerticalOptions="Center" />
                                    <Label Text="Gastos" TextColor="#6B7280" FontSize="12" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding TotalExpense, StringFormat='{0:C}'}"
                                       TextColor="#EF4444"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- New Transaction Form -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#FFFFFF"
                            Padding="20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,6" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Nueva Transacción"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <!-- Input: Description -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Descripción" TextColor="#374151" FontSize="12" FontAttributes="Bold" />
                                <Entry Text="{Binding DescriptionInput}"
                                       Placeholder="Ej. Almuerzo, Sueldo, Gasolina"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       BackgroundColor="#F9FAFB"
                                       HeightRequest="44" />
                            </VerticalStackLayout>

                            <!-- Input: Amount -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Monto" TextColor="#374151" FontSize="12" FontAttributes="Bold" />
                                <Entry Text="{Binding AmountInput}"
                                       Placeholder="Ej. 25.50"
                                       Keyboard="Numeric"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       BackgroundColor="#F9FAFB"
                                       HeightRequest="44" />
                            </VerticalStackLayout>

                            <!-- Transaction Type Selector: Expense / Income -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tipo de Transacción" TextColor="#374151" FontSize="12" FontAttributes="Bold" />
                                <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                    
                                    <!-- Expense Button -->
                                    <Button Grid.Column="0"
                                            Text="Gasto"
                                            Command="{Binding SetTypeCommand}"
                                            CommandParameter="Expense"
                                            CornerRadius="8"
                                            HeightRequest="40"
                                            FontAttributes="Bold">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsExpense}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#EF4444" />
                                                <Setter Property="TextColor" Value="#FFFFFF" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsExpense}" Value="False">
                                                <Setter Property="BackgroundColor" Value="#E5E7EB" />
                                                <Setter Property="TextColor" Value="#374151" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <!-- Income Button -->
                                    <Button Grid.Column="1"
                                            Text="Ingreso"
                                            Command="{Binding SetTypeCommand}"
                                            CommandParameter="Income"
                                            CornerRadius="8"
                                            HeightRequest="40"
                                            FontAttributes="Bold">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsExpense}" Value="False">
                                                <Setter Property="BackgroundColor" Value="#10B981" />
                                                <Setter Property="TextColor" Value="#FFFFFF" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsExpense}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#E5E7EB" />
                                                <Setter Property="TextColor" Value="#374151" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Add Button -->
                            <Button Text="Agregar Transacción"
                                    Command="{Binding AddTransactionCommand}"
                                    BackgroundColor="#4F46E5"
                                    TextColor="#FFFFFF"
                                    CornerRadius="10"
                                    HeightRequest="48"
                                    FontAttributes="Bold"
                                    Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- History Title -->
                    <Label Text="Historial de Transacciones"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           Margin="0,8,0,0" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- List of Transactions -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Transaction">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#FFFFFF"
                            Padding="12,14"
                            Margin="0,0,0,8">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="4" Opacity="0.04" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="4, *, Auto, Auto" ColumnSpacing="12" VerticalOptions="Center">
                            
                            <!-- Lateral indicator bar -->
                            <BoxView Grid.Column="0"
                                     WidthRequest="4"
                                     CornerRadius="2"
                                     VerticalOptions="Fill">
                                <BoxView.Triggers>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding Type}" Value="Income">
                                        <Setter Property="Color" Value="#10B981" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="BoxView" Binding="{Binding Type}" Value="Expense">
                                        <Setter Property="Color" Value="#EF4444" />
                                    </DataTrigger>
                                </BoxView.Triggers>
                            </BoxView>

                            <!-- Description and Date -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding Description}"
                                       TextColor="#1F2937"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Date, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                       TextColor="#6B7280"
                                       FontSize="11" />
                            </VerticalStackLayout>

                            <!-- Amount -->
                            <Label Grid.Column="2"
                                   Text="{Binding Amount, StringFormat='{0:C}'}"
                                   VerticalOptions="Center"
                                   FontSize="16"
                                   FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="Income">
                                        <Setter Property="TextColor" Value="#10B981" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="Expense">
                                        <Setter Property="TextColor" Value="#EF4444" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <!-- Delete Button -->
                            <Button Grid.Column="3"
                                    Text="🗑"
                                    TextColor="#EF4444"
                                    BackgroundColor="Transparent"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Padding="0"
                                    HeightRequest="36"
                                    WidthRequest="36"
                                    CornerRadius="18"
                                    Command="{Binding BindingContext.DeleteTransactionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                    CommandParameter="{Binding .}" />

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Empty state view -->
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center" Padding="30">
                    <Label Text="No hay transacciones registradas"
                           TextColor="#9CA3AF"
                           FontSize="14"
                           HorizontalTextAlignment="Center" />
                    <Label Text="¡Comienza registrando un ingreso o un gasto!"
                           TextColor="#D1D5DB"
                           FontSize="12"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>
    </Grid>

</ContentPage>
