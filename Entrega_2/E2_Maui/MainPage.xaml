<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:E2_Maui.ViewModels"
             xmlns:converters="clr-namespace:E2_Maui.Converters"
             x:Class="E2_Maui.MainPage"
             x:DataType="viewModels:MainViewModel"
             BackgroundColor="{StaticResource PageBackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:CurrencyFormatConverter x:Key="CurrencyFormatConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="..."
                     Order="Primary"
                     Priority="0"
                     Clicked="OnMoreOptionsClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout
            Padding="{StaticResource PagePadding}"
            Spacing="{StaticResource SectionSpacing}">

            <Label
                Text="Calculadora de Propina"
                Style="{StaticResource TitleLabelStyle}" />

            <Label
                Text="Ingresa el consumo, las personas y ajusta la propina."
                Style="{StaticResource SubtitleLabelStyle}" />

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="{StaticResource CardSpacing}">
                    <Label
                        Text="Total de consumo"
                        Style="{StaticResource SectionLabelStyle}" />

                    <Entry
                        Keyboard="Numeric"
                        Text="{Binding TotalConsumptionText}"
                        Placeholder="0"
                        Style="{StaticResource InputEntryStyle}" />

                    <Label
                        Text="Numero de personas"
                        Style="{StaticResource SectionLabelStyle}" />

                    <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="10">

                        <!-- Botón menos -->
                        <Button
                            Text="-"
                            Command="{Binding DecreasePeopleCommand}" />

                        <!-- Entrada manual -->
                        <Entry
                            Grid.Column="1"
                            Keyboard="Numeric"
                            Text="{Binding PeopleCountText}"
                            Placeholder="1"
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource InputEntryStyle}" />

                        <!-- Botón más -->
                        <Button
                            Grid.Column="2"
                            Text="+"
                            Command="{Binding IncreasePeopleCommand}" />

                    </Grid>
                    <!-- <Entry
                        Keyboard="Numeric"
                        Text="{Binding PeopleCountText}"
                        Placeholder="1"
                        Style="{StaticResource InputEntryStyle}" /> /!-->
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="{StaticResource CardSpacing}">
                    <Label
                        Text="Propina"
                        Style="{StaticResource SectionLabelStyle}" />

                    <Grid
                        x:Name="TipButtonsPanel"
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="{StaticResource ButtonSpacing}">
                        <Button
                            Text="10%"
                            Command="{Binding ApplyPresetTipCommand}"
                            CommandParameter="{x:Int32 10}"
                            Style="{StaticResource TipPresetButtonStyle}" />
                        <Button
                            Grid.Column="1"
                            Text="15%"
                            Command="{Binding ApplyPresetTipCommand}"
                            CommandParameter="{x:Int32 15}"
                            Style="{StaticResource TipPresetButtonStyle}" />
                        <Button
                            Grid.Column="2"
                            Text="20%"
                            Command="{Binding ApplyPresetTipCommand}"
                            CommandParameter="{x:Int32 20}"
                            Style="{StaticResource TipPresetButtonStyle}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource ButtonSpacing}">
                        <Slider
                            x:Name="TipSlider"
                            Minimum="0"
                            Maximum="50"
                            Value="{Binding TipPercent}" />
                        <Label
                            Text="{Binding TipPercent, StringFormat='{}{0:F0}%'}"
                            Style="{StaticResource PercentLabelStyle}"
                            Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultsCard" Style="{StaticResource ResultCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource ResultSpacing}">
                    <Label
                        Text="Resultados por persona"
                        Style="{StaticResource SectionLabelStyle}" />

                    <Grid
                        RowDefinitions="Auto,Auto,Auto"
                        ColumnDefinitions="*,Auto"
                        RowSpacing="{StaticResource ResultRowSpacing}">
                        <Label
                            Text="Subtotal"
                            Style="{StaticResource ResultCaptionLabelStyle}" />
                        <Label
                            Grid.Column="1"
                            Style="{StaticResource ResultValueLabelStyle}">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource CurrencyFormatConverter}">
                                    <Binding Path="SubtotalPerPerson" />
                                    <Binding Path="SelectedCurrencyCulture" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>

                        <Label
                            Grid.Row="1"
                            Text="Propina"
                            Style="{StaticResource ResultCaptionLabelStyle}" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ResultValueLabelStyle}">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource CurrencyFormatConverter}">
                                    <Binding Path="TipPerPerson" />
                                    <Binding Path="SelectedCurrencyCulture" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>

                        <Label
                            Grid.Row="2"
                            Text="Total p/persona"
                            Style="{StaticResource ResultCaptionLabelStyle}" />
                        <Label
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ResultValueLabelStyle}">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource CurrencyFormatConverter}">
                                    <Binding Path="TotalPerPerson" />
                                    <Binding Path="SelectedCurrencyCulture" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Grid>

                    <Grid
                        RowDefinitions="Auto,Auto"
                        ColumnDefinitions="*,Auto"
                        RowSpacing="{StaticResource ResultRowSpacing}">
                        <Label
                            Text="Propina total"
                            Style="{StaticResource ResultCaptionLabelStyle}" />
                        <Label
                            Grid.Column="1"
                            Style="{StaticResource ResultValueLabelStyle}">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource CurrencyFormatConverter}">
                                    <Binding Path="TipAmountTotal" />
                                    <Binding Path="SelectedCurrencyCulture" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>

                        <Label
                            Grid.Row="1"
                            Text="Total con propina"
                            Style="{StaticResource ResultCaptionLabelStyle}" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ResultValueLabelStyle}">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource CurrencyFormatConverter}">
                                    <Binding Path="TotalWithTip" />
                                    <Binding Path="SelectedCurrencyCulture" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
